{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A contact lens product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "brand": { "type": "string" },
        "color": { "type": "string" },
        "dia": { "type": "number" },
        "bc": { "type": "number" },
        "power": { "type": "string" },
        "duration": { "type": "string" },
        "price": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "shortDescription": { "type": "string" },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "seoContent": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "SEO Blog Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "coverImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of contact lens products"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of product categories"
    },
    "blogPosts": {
      "schema": "BlogPost",
      "description": "Collection of SEO blog posts"
    }
  }
}
